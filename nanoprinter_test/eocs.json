[
  {
    "type": "effect_on_condition",
    "id": "EOC_NANOPRINTER_CONSOLE_MAIN",
    "//": "Main console interface - shows crafting menu",
    "global": true,
    "effect": {
      "run_eoc_selector": [
        "EOC_NANOPRINTER_PRINT_BANDAGE",
        "EOC_NANOPRINTER_PRINT_WATER",
        "EOC_NANOPRINTER_PRINT_RATION",
        "EOC_NANOPRINTER_PRINT_CABLE",
        "EOC_NANOPRINTER_EXIT"
      ],
      "names": [
        "Print Bandages (1 plastic)",
        "Print Water Bottle (1 plastic)",
        "Print Ration Pack (2 organic)",
        "Print Extension Cable (2 metal)",
        "Exit"
      ],
      "keys": [ "1", "2", "3", "4", "0" ],
      "descriptions": [
        "Fabricate 2 sterile bandages for medical use.",
        "Fabricate 1 bottle of clean water.",
        "Fabricate 1 ration pack for sustenance.",
        "Fabricate 1 extension cable for power connections.",
        "Close the console interface."
      ]
    }
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_NANOPRINTER_PRINT_BANDAGE",
    "//": "Print bandages - costs 1 plastic chunk",
    "global": true,
    "condition": {
      "and": [
        { "u_has_item": "plastic_chunk" }
      ]
    },
    "effect": [
      { "u_consume_item": "plastic_chunk", "count": 1 },
      { "u_spawn_item": "bandage", "count": 2 },
      { "u_message": "The nanoprinter whirs softly and fabricates 2 sterile bandages.", "type": "good" },
      { "u_make_sound": "a soft whirring", "volume": 5 }
    ],
    "false_effect": {
      "u_message": "Not enough plastic chunks. Need 1.",
      "popup": true,
      "type": "bad"
    }
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_NANOPRINTER_PRINT_WATER",
    "//": "Print water bottle - costs 1 plastic chunk",
    "global": true,
    "condition": {
      "and": [
        { "u_has_item": "plastic_chunk" }
      ]
    },
    "effect": [
      { "u_consume_item": "plastic_chunk", "count": 1 },
      { "u_spawn_item": "water_clean", "count": 1, "container": "bottle_plastic" },
      { "u_message": "The nanoprinter materializes clean water inside a plastic bottle.", "type": "good" },
      { "u_make_sound": "a soft whirring", "volume": 5 }
    ],
    "false_effect": {
      "u_message": "Not enough plastic chunks. Need 1.",
      "popup": true,
      "type": "bad"
    }
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_NANOPRINTER_PRINT_RATION",
    "//": "Print ration pack - costs 2 organic chunks",
    "global": true,
    "condition": {
      "and": [
        { "u_has_item": "organic_chunk" }
      ]
    },
    "effect": [
      { "u_consume_item": "organic_chunk", "count": 2 },
      { "u_spawn_item": "ration", "count": 1 },
      { "u_message": "The nanoprinter synthesizes a nutritious ration pack.", "type": "good" },
      { "u_make_sound": "a soft whirring", "volume": 5 }
    ],
    "false_effect": {
      "u_message": "Not enough organic chunks. Need 2.",
      "popup": true,
      "type": "bad"
    }
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_NANOPRINTER_PRINT_CABLE",
    "//": "Print extension cable - costs 2 metal chunks",
    "global": true,
    "condition": {
      "and": [
        { "u_has_item": "metal_chunk" }
      ]
    },
    "effect": [
      { "u_consume_item": "metal_chunk", "count": 2 },
      { "u_spawn_item": "extension_cable", "count": 1 },
      { "u_message": "The nanoprinter fabricates an extension cable.", "type": "good" },
      { "u_make_sound": "a soft whirring", "volume": 5 }
    ],
    "false_effect": {
      "u_message": "Not enough metal chunks. Need 2.",
      "popup": true,
      "type": "bad"
    }
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_NANOPRINTER_EXIT",
    "//": "Exit console interface",
    "global": true,
    "effect": {
      "u_message": "You close the console interface."
    }
  }
]
